{
	"compilerOptions": {
		// Environment setup & latest features
		// DOM/DOM.Iterable are needed for src/dashboard/** (browser-side React
		// code, e.g. window/document/HTMLInputElement) -- everything else in
		// src/ runs under Bun, which layers its own fetch/Request/Response
		// types over these via the "bun" entry in `types` below.
		"lib": ["ESNext", "DOM", "DOM.Iterable"],
		"target": "ESNext",
		"module": "Preserve",
		"moduleDetection": "force",
		"jsx": "react-jsx",
		"allowJs": true,
		// Bundler mode
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"verbatimModuleSyntax": true,
		"noEmit": true,
		"types": ["bun"],
		// Best practices
		"strict": true,
		"skipLibCheck": true,
		"noFallthroughCasesInSwitch": true,
		"noUncheckedIndexedAccess": true,
		"noImplicitOverride": true,
		// Some stricter flags (disabled by default)
		"noUnusedLocals": false,
		"noUnusedParameters": false,
		"noPropertyAccessFromIndexSignature": false
	},
	"include": ["src/**/*"]
}
